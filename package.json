{
  "name": "fcn-pressespiegel",
  "version": "1.0.0",
  "description": "FCN Pressespiegel",
  "author": "Stefan Helmer <mail@clubfans-united.de>",
  "license": "UNLICENSED",
  "private": true,
  "files": [
    "fcn-pressespiegel.php",
    "src",
    "templates",
    "dist",
    "vendor"
  ],
  "config": {
    "webpack_src_dir": "js/Blocks",
    "output_path": "dist/wp",
    "resources_js_dir": "js/**/*.{js,jsx}"
  },
  "scripts": {
    "build": "wp-scripts build --webpack-copy-php --webpack-src-dir=$npm_package_config_webpack_src_dir --output-path=$npm_package_config_output_path",
    "start": "wp-scripts start --webpack-copy-php --webpack-src-dir=$npm_package_config_webpack_src_dir --output-path=$npm_package_config_output_path",
    "lint": "biome lint js",
    "lint-fix": "biome lint --write js",
    "format": "biome format --write js",
    "format-check": "biome format js",
    "check": "biome check js",
    "check-fix": "biome check --write js",
    "packages-update": "wp-scripts packages-update",
    "postpackages-update": "npm run build",
    "plugin-zip": "wp-scripts plugin-zip"
  },
  "lint-staged": {
    "*.{js,jsx}": "biome check --write --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@wordpress/scripts": "^30.12.1",
    "mustard-ui": "^1.0.4",
    "prop-types": "^15.8.1",
    "query-string": "^7.1.1",
    "react-tag-input-component": "^1.1.1",
    "resolve-url-loader": "^5.0.0",
    "sass-loader": "^12.6.0"
  }
}
