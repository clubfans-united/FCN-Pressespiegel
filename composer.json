{
  "name": "clubfansunited/pressespiegel",
  "description": "WordPress Plugin FCN Pressespiegel",
  "type": "project",
  "license": "proprietary",
  "authors": [
    {
      "name": "Stefan Helmer",
      "email": "mail@clubfans-united.de",
      "homepage": "https://www.eracer.de"
    }
  ],
  "config": {
    "preferred-install": "dist",
    "sort-packages": true
  },
  "require": {
    "php": ">=8.3",
    "laminas/laminas-feed": "^2.25",
    "nesbot/carbon": "2.*",
    "ozh/bookmarkletgen": "1.*"
  },
  "require-dev": {
    "brain/monkey": "^2.7",
    "friendsofphp/php-cs-fixer": "^3.95",
    "kint-php/kint": "3.*",
    "phpunit/phpunit": "^12.5",
    "roave/security-advisories": "dev-latest"
  },
  "scripts": {
    "test": [
      "vendor/bin/php-cs-fixer check",
      "vendor/bin/phpunit"
    ]
  },
  "autoload": {
    "psr-4": {
      "FCNPressespiegel\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "FCNPressespiegel\\Tests\\": "tests/"
    }
  }
}
